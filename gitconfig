[core]
    editor          = vim
    excludesfile    = ~/.gitignore
    autocrlf        = input

[color]
    ui              = auto

[color "status"]
    added           = green
    changed         = yellow
    untracked       = red

[colors "branch"]
    current         = yellow reverse
    local           = yellow
    remote          = green

[color "diff"]
    meta            = yellow bold
    frag            = magenta bold
    old             = red bold
    new             = green bold

[diff]
    tool            = vimdiff

[merge]
    tool            = vimdiff

[alias]
    tree = log --graph --all --decorate --oneline

